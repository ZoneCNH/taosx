# ============================================================
# taosx 环境变量模板
# 复制为 .env 后填入实际值（.env 已在 .gitignore 中排除）
#
# TDengine L2 adapter — 真实 TDengine WebSocket 集成由环境变量注入
# ============================================================

# ---- 集成测试开关 ----
# 设为 1 启用真实 TDengine WebSocket 集成测试（默认跳过）
TAOSX_INTEGRATION=0

# ---- TDengine 连接参数（TAOSX_INTEGRATION=1 时必需）----
# WebSocket 端点（例：ws://localhost:6041/ws）
TAOSX_TDENGINE_ENDPOINT=
# 用户名
TAOSX_TDENGINE_USER=root
# 密码
TAOSX_TDENGINE_PASSWORD=taosdata
# 数据库名
TAOSX_TDENGINE_DATABASE=test
# 是否启用 TLS
# TAOSX_TDENGINE_TLS=0
# 备选：直接提供完整 DSN
# TAOSX_TDENGINE_DSN=
