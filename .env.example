# ============================================================
# taosx 环境变量模板
# 复制为 .env 后填入实际值
# .env 文件已在 .gitignore 中排除，禁止提交
#
# 密钥命名约定：前缀 FOUNDATIONX_TAOSX_
# ============================================================

# ---- 实例标识 ----
FOUNDATIONX_TAOSX_NAME=taosx

# ---- 驱动模式 ----
# 合法值：websocket | native_legacy | rest_sql_only
FOUNDATIONX_TAOSX_DRIVER_MODE=websocket

# ---- TDengine 连接 ----
FOUNDATIONX_TAOSX_ENDPOINT=127.0.0.1:6041
FOUNDATIONX_TAOSX_DATABASE=dev_taosx
FOUNDATIONX_TAOSX_USERNAME=root
FOUNDATIONX_TAOSX_PASSWORD=

# ---- 操作超时（如 5s, 10s, 30s） ----
FOUNDATIONX_TAOSX_TIMEOUT=5s
FOUNDATIONX_TAOSX_MAX_RETRIES=3

# ---- TLS ----
FOUNDATIONX_TAOSX_TLS=false
